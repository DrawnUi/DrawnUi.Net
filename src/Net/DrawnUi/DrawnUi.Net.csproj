<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <PropertyGroup>
        <DefineConstants>$(DefineConstants);DRAWNUI_NET</DefineConstants>
    </PropertyGroup>

    <PropertyGroup>
        <Title>DrawnUI for .NET</Title>
        <PackageId>DrawnUi.Net</PackageId>
        <Description>Rendering engine for .NET to draw with SkiaSharp</Description>
        <PackageTags>drawnui skia skiasharp draw ui net</PackageTags>
        <PackageIcon>icon128.png</PackageIcon>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <CreatePackage>false</CreatePackage>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <NoWarn>1701;1702;XLS0505</NoWarn>
        <WarningsAsErrors>$(WarningsAsErrors);CS0108;XLS0501</WarningsAsErrors>
    </PropertyGroup>

    <ItemGroup Condition=" '$(Configuration)'=='Release' ">
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\..\icon128.png">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Include="..\..\Directory.Build.targets" Link="Directory.Build.targets" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="AppoMobi.Gestures" Version="3.10.1" />
        <PackageReference Include="SkiaSharp.HarfBuzz" Version="4.147.0-pr.3779.2" />
        <PackageReference Include="SkiaSharp.Skottie" Version="4.147.0-pr.3779.2" />
        <PackageReference Include="Svg.Skia" Version="3.0.3" />
        <PackageReference Include="CommonMark.NET" Version="0.15.1" />
        <PackageReference Include="AppoMobi.Specials" Version="9.0.3" />
        <PackageReference Include="EasyCaching.InMemory" Version="1.9.2" />
        <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="9.0.6" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\SkiaCursor.cs" Link="Draw\EditText\SkiaCursor.cs" />
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\SkiaEditor.cs" Link="Draw\EditText\SkiaEditor.cs" />
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\SkiaEditorSelection.cs" Link="Draw\EditText\SkiaEditorSelection.cs" />
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\RichCharFormat.cs" Link="Draw\EditText\RichCharFormat.cs" Condition="'$(Configuration)'=='Debug'" />
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\SkiaEditorDocument.cs" Link="Draw\EditText\SkiaEditorDocument.cs" Condition="'$(Configuration)'=='Debug'" />
        <Compile Include="..\..\Maui\DrawnUi\Draw\EditText\SkiaRichEditor.cs" Link="Draw\EditText\SkiaRichEditor.cs" Condition="'$(Configuration)'=='Debug'" />
    </ItemGroup>

    <Import Project="..\..\Shared\Shared.projitems" Label="Shared" />
    <Import Project="..\..\SharedNet\SharedNet.projitems" Label="SharedNet" />

    <ItemGroup>
        <Compile Remove="$(MSBuildThisFileDirectory)..\..\Shared\Features\Pdf\Pdf.cs" />
        <Compile Remove="$(MSBuildThisFileDirectory)..\..\Shared\Draw\Base\VisualTreeHandler.cs" />
    </ItemGroup>

</Project>