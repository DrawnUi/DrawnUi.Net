@page "/gif-probe"
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

@using DrawnUi

<PageTitle>SkiaGif</PageTitle>

<div class="docs-page">
    <h1>SkiaGif</h1>
    <p class="docs-lead" id="gif-probe-description">SkiaGif is the straightforward way to host animated GIF assets inside a DrawnUI surface.</p>
    <p class="docs-note">This page keeps one looping local animation visible together with a live status line, which makes it useful both as a demo and as a quick sanity check when working on media loading.</p>
</div>
<p id="gif-local-status">@_gifStatus</p>

<Canvas Content="_canvasContent" WidthRequest="420"
        HeightRequest="560"
        BackgroundColor="#EFF5F8"
        Margin="0,16,0,32"
         />

@code {
    private SkiaControl _canvasContent;
    private string _gifStatus = "gif local: pending";

    public GifProbe()
    {
        var gif = new SkiaGif()
        {
            WidthRequest = 280,
            HeightRequest = 180,
            HorizontalOptions = LayoutOptions.Center,
            Aspect = TransformAspect.AspectFit,
            AutoPlay = true,
            Repeat = -1,
            SpeedRatio = 0.8,
            Source = "media/banana.gif"
        };

        gif.Success += (_, source) => SetGifStatus($"gif local: loaded {source}");
        gif.Error += (_, exception) => SetGifStatus($"gif local: error {exception.Message}");

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 388,
            HeightRequest = 520,
            Padding = new Thickness(20),
            BackgroundColor = new Color(0.976f, 0.984f, 0.992f, 1f),
            Type = LayoutType.Column,
            Spacing = 16,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaGif",
                    FontFamily = "FontTextTitle",
                    FontSize = 28,
                    TextColor = new Color(0.133f, 0.184f, 0.251f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "Local GIF asset, autoplay, repeat, and fit behavior in one compact sample.",
                    FontFamily = "FontText",
                    FontSize = 15,
                    TextColor = new Color(0.290f, 0.341f, 0.408f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaShape()
                {
                    WidthRequest = 348,
                    HeightRequest = 280,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 22,
                    BackgroundColor = Colors.White,
                    StrokeColor = new Color(0.518f, 0.620f, 0.725f, 1f),
                    StrokeWidth = 1,
                    Padding = new Thickness(18),
                    Children =
                    {
                        new SkiaLayout()
                        {
                            Type = LayoutType.Column,
                            Spacing = 12,
                            VerticalOptions = LayoutOptions.Fill,
                            Children =
                            {
                                new SkiaLabel()
                                {
                                    Text = "Local gif via package-style source",
                                    FontFamily = "FontTextTitle",
                                    FontSize = 18,
                                    TextColor = new Color(0.184f, 0.243f, 0.310f, 1f),
                                    HorizontalOptions = LayoutOptions.Fill
                                },
                                gif
                            }
                        }
                    }
                }
            }
        };
    }

    private void SetGifStatus(string value)
    {
        _gifStatus = value;
        Console.WriteLine($"[GifProbe] {value}");
        _ = InvokeAsync(StateHasChanged);
    }
}