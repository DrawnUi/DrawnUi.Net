@page "/labels-rich"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaRichLabel</PageTitle>

<div class="docs-page">
    <h1>SkiaRichLabel</h1>
    <p class="docs-lead">SkiaRichLabel is the richer text variant when a plain SkiaLabel starts feeling too flat. In the public preview this page stays on the stable side: multiline text, spacing, alignment, and a more expressive presentation block.</p>
    <p class="docs-note">This sample is intentionally conservative. It shows a copyable rich-text card that already behaves well in Blazor instead of turning the page into a markdown torture test.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" 
                WidthRequest="360"
                HeightRequest="360"
                BackgroundColor="#F5EFE6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@RichLabelSnippet</code></pre>
</div>

@code {
    private const string RichLabelSnippet = """
new SkiaRichLabel()
{
    HorizontalTextAlignment = DrawTextAlignment.Center,
    HorizontalOptions = LayoutOptions.Fill,
    LineHeight = 1,
    CharacterSpacing = 1.1,
    FontSize = 18,
    Text = "Richer text blocks, still drawn in the same pipeline.\r\nNo HTML widgets required.",
    TextColor = Colors.Orange,
};
""";

    private SkiaControl _canvasContent;

    public LabelsRich()
    {
        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 296,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaRichLabel",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaRichLabel()
                {
                    UseCache = SkiaCacheType.Operations,
                    HorizontalTextAlignment = DrawTextAlignment.Center,
                    HorizontalOptions = LayoutOptions.Fill,
                    LineHeight = 1,
                    CharacterSpacing = 1.1,
                    FontSize = 18,
                    Text = "Richer text blocks, still drawn in the same pipeline.\r\nNo HTML widgets required.",
                    TextColor = new Color(0.788f, 0.431f, 0.098f, 1f),
                },
                new SkiaShape()
                {
                    Padding = new Thickness(8),
                    WidthRequest = 292,
                    HeightRequest = 188,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 18,
                    BackgroundColor = Colors.White,
                    StrokeColor = new Color(0.851f, 0.827f, 0.776f, 1f),
                    StrokeWidth = 1,
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        new SkiaRichLabel()
                        {
                            WidthRequest = 248,
                            Text = "Use SkiaRichLabel for callouts, hero copy, and multiline text blocks when a plain label feels too bare.\n\nThis preview keeps the demo stable.",
                            FontFamily = "FontText",
                            FontSize = 13,
                            LineSpacing = 1.35,
                            TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center,
                            HorizontalTextAlignment = DrawTextAlignment.Center
                        }
                    }
                }
            }
        };
    }
}