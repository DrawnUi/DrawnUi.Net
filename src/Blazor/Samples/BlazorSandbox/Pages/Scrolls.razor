@page "/scrolls"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaScroll</PageTitle>

<div class="docs-page">
    <h1>SkiaScroll</h1>
    <p class="docs-lead">SkiaScroll is the base scroll container for drawn content. Use it for custom feeds, long forms, diagnostics surfaces, and any scrollable layout that should stay inside the DrawnUI tree.</p>
    <p class="docs-note">Drag inside the scroll frame. The header stays visible while the cards move underneath it.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                BackgroundColor="@Color.Parse("#F6F0E6")"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@ScrollSnippet</code></pre>
</div>

@code {
    private const string ScrollSnippet = """
var scroll = new SkiaScroll()
{
    HeaderSticky = true,
    Header = new SkiaLabel() { Text = "Sticky header" },
    Content = new SkiaLayout() { Type = LayoutType.Column }
};
""";

    private SkiaControl _canvasContent;

    public Scrolls()
    {
        var content = new SkiaLayout()
        {
            HorizontalOptions = LayoutOptions.Fill,
            Type = LayoutType.Column,
            Spacing = 14,
            Padding = new Thickness(12, 64, 12, 20)
        };

        for (var index = 0; index < 6; index++)
        {
            content.AddSubView(CreateCard(index));
        }

        var scroll = new SkiaScroll()
        {
            HeightRequest = 236,
            HorizontalOptions = LayoutOptions.Fill,
            BackgroundColor = new Color(0.988f, 0.985f, 0.973f, 1f),
            HeaderSticky = true,
            Header = new SkiaShape()
            {
                HorizontalOptions = LayoutOptions.Fill,
                HeightRequest = 56,
                CornerRadius = 20,
                BackgroundColor = new Color(0.118f, 0.180f, 0.286f, 1f),
                Children =
                {
                    new SkiaLayout()
                    {
                        Padding = new Thickness(16, 10, 16, 14),
                        Type = LayoutType.Row,
                        HorizontalOptions = LayoutOptions.Fill,
                        VerticalOptions = LayoutOptions.Fill,
                        Children =
                        {
                            new SkiaLayout()
                            {
                                Type = LayoutType.Column,
                                Spacing = 1,
                                HorizontalOptions = LayoutOptions.Fill,
                                VerticalOptions = LayoutOptions.Center,
                                Children =
                                {
                                    new SkiaLabel()
                                    {
                                        Text = "Sticky header",
                                        FontFamily = "FontTextTitle",
                                        FontSize = 15,
                                        TextColor = Colors.White,
                                        HorizontalOptions = LayoutOptions.Fill
                                    },
                                    new SkiaLabel()
                                    {
                                        Text = "Keeps the feed anchored.",
                                        FontFamily = "FontText",
                                        FontSize = 11,
                                        TextColor = new Color(0.831f, 0.867f, 0.925f, 1f),
                                        HorizontalOptions = LayoutOptions.Fill
                                    }
                                }
                            },
                            new SkiaShape()
                            {
                                WidthRequest = 42,
                                HeightRequest = 24,
                                Type = ShapeType.Rectangle,
                                CornerRadius = 99,
                                BackgroundColor = new Color(0.220f, 0.435f, 0.710f, 1f),
                                VerticalOptions = LayoutOptions.Center,
                                Children =
                                {
                                    new SkiaLabel()
                                    {
                                        Text = "Live",
                                        FontFamily = "FontTextTitle",
                                        FontSize = 11,
                                        TextColor = Colors.White,
                                        HorizontalOptions = LayoutOptions.Center,
                                        VerticalOptions = LayoutOptions.Center
                                    }
                                }
                            }
                        }
                    }
                }
            },
            Content = content
        };

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            HorizontalOptions = LayoutOptions.Fill,
            Padding = new Thickness(20),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaScroll",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                scroll
            }
        };
    }

    private static SkiaShape CreateCard(int index)
    {
        var shades = new[]
        {
            new Color(0.922f, 0.941f, 0.976f, 1f),
            new Color(0.969f, 0.925f, 0.898f, 1f),
            new Color(0.922f, 0.961f, 0.929f, 1f)
        };

        var accents = new[]
        {
            new Color(0.208f, 0.447f, 0.761f, 1f),
            new Color(0.812f, 0.427f, 0.216f, 1f),
            new Color(0.224f, 0.522f, 0.365f, 1f)
        };

        var titles = new[]
        {
            "Diagnostics feed",
            "Pinned surface",
            "Touch telemetry",
            "Runtime notes",
            "Viewport audit",
            "Gesture summary"
        };

        return new SkiaShape()
        {
            HeightRequest = 82,
            Type = ShapeType.Rectangle,
            CornerRadius = 16,
            BackgroundColor = shades[index % shades.Length],
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                new SkiaLayout()
                {
                    Padding = new Thickness(14, 12, 14, 14),
                    Type = LayoutType.Column,
                    Spacing = 6,
                    Children =
                    {
                        new SkiaLayout()
                        {
                            Type = LayoutType.Row,
                            Spacing = 8,
                            Children =
                            {
                                new SkiaShape()
                                {
                                    WidthRequest = 30,
                                    HeightRequest = 6,
                                    Type = ShapeType.Rectangle,
                                    CornerRadius = 99,
                                    BackgroundColor = accents[index % accents.Length],
                                    VerticalOptions = LayoutOptions.Center
                                },
                                new SkiaLabel()
                                {
                                    Text = titles[index % titles.Length],
                                    FontFamily = "FontTextTitle",
                                    FontSize = 15,
                                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                                    HorizontalOptions = LayoutOptions.Fill,
                                    VerticalOptions = LayoutOptions.Center
                                }
                            }
                        },
                        new SkiaLabel()
                        {
                            Text = "Reusable for long drawn feeds, settings pages, or custom list content.",
                            FontFamily = "FontText",
                            FontSize = 11,
                            TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                            HorizontalOptions = LayoutOptions.Fill,
                        }
                    }
                }
            }
        };
    }
}