@page "/sliders"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaSlider</PageTitle>

<div class="docs-page">
    <h1>SkiaSlider</h1>
    <p class="docs-lead">Drag the thumb to change a value. Set <code>EnableRange = true</code> and supply a <code>Start</code> value to activate dual-thumb range selection.</p>
    <p class="docs-note">Drag either thumb. The label above each slider reflects the current value.</p>

    <div class="docs-example-frame">
        <Canvas
            Content="_canvasContent"
            WidthRequest="360"
            BackgroundColor="#F5F0E5"
            Margin="0,8,0,0"
            Gestures="@GesturesMode.SoftLock" />
    </div>

    <pre class="docs-code"><code>@SliderSnippet</code></pre>
</div>

@code {
    private const string SliderSnippet = """
// Non-ranged — single thumb, built-in Cupertino style:
var slider = new SkiaSlider
{
    ControlStyle = PrebuiltControlStyle.Cupertino,
    HorizontalOptions = LayoutOptions.Fill,
    Min = 0, Max = 100, End = 40
};
slider.EndChanged += (_, value) => label.Text = $"Value: {value:0}";

// Ranged Cupertino — EnableRange adds StartThumb automatically:
var cupertinoRange = new SkiaSlider
{
    ControlStyle = PrebuiltControlStyle.Cupertino,
    EnableRange = true,
    HorizontalOptions = LayoutOptions.Fill,
    Min = 0, Max = 100, Start = 20, End = 70, RangeMin = 5
};
cupertinoRange.StartChanged += (_, _) => UpdateLabel(cupertinoRange);
cupertinoRange.EndChanged   += (_, _) => UpdateLabel(cupertinoRange);

// Ranged Default style — same pattern, different look:
var defaultRange = new SkiaSlider
{
    EnableRange = true,
    HorizontalOptions = LayoutOptions.Fill,
    Min = 0, Max = 200, Start = 40, End = 120, Step = 5, RangeMin = 10
};
""";

    private SkiaLabel _valueLabel;
    private SkiaLabel _rangeLabel;
    private SkiaLabel _rangeLabel2;
    private SkiaControl _canvasContent;

    public class DebugMe : SkiaStack
    {
        public DebugMe()
        {
            BackgroundColor = Colors.Red;
            HorizontalOptions = LayoutOptions.Fill;
        }

        public override ScaledSize OnMeasuring(float widthConstraint, float heightConstraint, float scale)
        {
            var ret = base.OnMeasuring(widthConstraint, heightConstraint, scale);
            Console.WriteLine($"[DEBUG] {ret.Pixels} for {widthConstraint}x{heightConstraint} at {scale}");
            return ret;
        }
    }

    public Sliders()
    {



        var slider = new SkiaSlider
        {
            HorizontalOptions = LayoutOptions.Fill,
            Min = 0,
            Max = 100,
            End = 40,
        };
        slider.EndChanged += (_, value) => _valueLabel.Text = $"Value: {value:0}";

        var rangeSlider = new SkiaSlider
        {
            ControlStyle = PrebuiltControlStyle.Cupertino,
            EnableRange = true,
            HorizontalOptions = LayoutOptions.Fill,
            Min = 0,
            Max = 100,
            Start = 20,
            End = 70,
            RangeMin = 5,
        };
        rangeSlider.StartChanged += (_, _) => UpdateRangeLabel(_rangeLabel, rangeSlider);
        rangeSlider.EndChanged   += (_, _) => UpdateRangeLabel(_rangeLabel, rangeSlider);

        var rangeSlider2 = new SkiaSlider
        {
            EnableRange = true,
            HorizontalOptions = LayoutOptions.Fill,
            Min = 0,
            Max = 200,
            Start = 40,
            End = 120,
            Step = 5,
            RangeMin = 10,
        };
        rangeSlider2.StartChanged += (_, _) => UpdateRangeLabel(_rangeLabel2, rangeSlider2);
        rangeSlider2.EndChanged   += (_, _) => UpdateRangeLabel(_rangeLabel2, rangeSlider2);

        _valueLabel = new SkiaLabel
        {
            Text = "Value: 40",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
        };

        _rangeLabel = new SkiaLabel
        {
            Text = "Range: 20 – 70",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
        };

        _rangeLabel2 = new SkiaLabel
        {
            Text = "Range: 40 – 120",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
        };

        _canvasContent = new DebugMe
        {
            Margin = new Thickness(16),
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Spacing = 10,
            Children =
            {
                new SkiaLabel
                {
                    Text = "Standard Slider",
                    FontFamily = "FontTextTitle",
                    FontSize = 17,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                },
                _valueLabel,
                slider,

                Divider(),

                new SkiaLabel
                {
                    Text = "Range Slider (Cupertino)",
                    FontFamily = "FontTextTitle",
                    FontSize = 17,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                },
                _rangeLabel,
                rangeSlider,

                Divider(),

                new SkiaLabel
                {
                    Text = "Range Slider (Default style)",
                    FontFamily = "FontTextTitle",
                    FontSize = 17,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                },
                _rangeLabel2,
                rangeSlider2,
            }
        };
    }

    private static SkiaShape Divider() => new SkiaShape
    {
        HeightRequest = 1,
        UseCache = SkiaCacheType.Operations,
        HorizontalOptions = LayoutOptions.Fill,
        BackgroundColor = new Color(0.208f, 0.169f, 0.118f, 0.12f),
        Margin = new Thickness(0, 4),
    };

    private static void UpdateRangeLabel(SkiaLabel label, SkiaSlider slider)
    {
        label.Text = $"Range: {slider.Start:0} – {slider.End:0}";
    }
}
