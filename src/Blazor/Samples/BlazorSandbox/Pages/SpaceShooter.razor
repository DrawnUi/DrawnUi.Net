@page "/space-shooter"
@using DrawnUi.Draw
@using DrawnUi.Views
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Space Shooter</PageTitle>

<div class="docs-page">
    <h1>Space Shooter</h1>
    <p class="docs-lead">This is the loudest DrawnUI-for-Blazor demo in the sandbox: a full-scene accelerated surface with continuous animation, gestures, sprite updates, overlays, and a real game loop running in the browser.</p>
    <p class="docs-note">Try touch or mouse input, then switch to fullscreen. This page is less about individual controls and more about proving that DrawnUI can hold together under a much less polite workload than a normal UI sample.</p>
</div>

<FullscreenToggleBar
    IsFullscreen="@_isFullscreen"
    IsFullscreenChanged="OnFullscreenChanged" />

<div @ref="_viewportAnchor">
    <AspectLockedViewportHost
        AspectWidth="@ViewportWidth"
        AspectHeight="@ViewportHeight"
        BackgroundColor="#020816"
        IsFullscreen="@_isFullscreen"
        EmbeddedMargin="12px auto 0"
        FitVisibleHeight="true"
        ViewportOffsetPixels="@_viewportOffsetPixels">
        <AspectLockedCanvas 
            @ref="_canvas"
            Content="_canvasContent"
            LogicalWidth="@ViewportWidth"
            LogicalHeight="@ViewportHeight"
            HorizontalOptions="LayoutOptions.Fill"
            VerticalOptions="LayoutOptions.Fill"
            BackgroundColor="#020816"
            RenderingMode="@RenderingModeType.Accelerated"
            Gestures="@GesturesMode.Enabled"
            IsFullscreen="@_isFullscreen"
            IsFullscreenChanged="OnFullscreenChanged" />
    </AspectLockedViewportHost>
</div>

@code {

    /// <summary>
    /// Tune the locked game aspect here. The canvas always scales this logical portrait viewport without stretching.
    /// </summary>
    private const float ViewportWidth = 480f;

    /// <summary>
    /// Tune the locked game aspect here. Keep this paired with <see cref="ViewportWidth"/> to change the playable field ratio.
    /// </summary>
    private const float ViewportHeight = 800f;

    private SkiaControl _canvasContent;
    private AspectLockedCanvas _canvas;
    private bool _isFullscreen;
    private ElementReference _viewportAnchor;
    private float _viewportOffsetPixels;
    private IJSObjectReference? _layoutModule;
    private DotNetObjectReference<SpaceShooter>? _layoutCallbackRef;

    public SpaceShooter()
    {

        _canvasContent = new SkiaLayer()
        {
            VerticalOptions = LayoutOptions.Fill,
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                new global::SpaceShooter.Game.SpaceShooter()
                {
                    WidthRequest = ViewportWidth,
                    HeightRequest = ViewportHeight,
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center,
                },
                
                new SkiaLabelFps()
                {
                    UseCache = SkiaCacheType.GPU,
                    Margin = new (0, 0, 4, 24),
                    VerticalOptions = LayoutOptions.End,
                    HorizontalOptions = LayoutOptions.End,
                    Rotation = -45,
                    BackgroundColor = Colors.DarkRed,
                    TextColor = Colors.White,
                    ZIndex = 110,
                }
            }
        };


    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        _layoutModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Pages/SpaceShooter.razor.js");
        _layoutCallbackRef ??= DotNetObjectReference.Create(this);

        await _layoutModule.InvokeVoidAsync("attachViewportOffsetObserver", _viewportAnchor, _layoutCallbackRef);
    }

    [JSInvokable]
    public async Task OnViewportOffsetChanged(double offset)
    {
        var nextOffset = (float)Math.Max(0, Math.Round(offset));
        if (Math.Abs(_viewportOffsetPixels - nextOffset) < 0.5f)
            return;

        _viewportOffsetPixels = nextOffset;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnFullscreenChanged(bool isFullscreen)
    {
        _isFullscreen = isFullscreen;
        _canvas?.InvalidateChildren();

        if (_layoutModule != null)
        {
            await _layoutModule.InvokeVoidAsync("refreshViewportOffset", _viewportAnchor);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_layoutModule != null)
        {
            try
            {
                await _layoutModule.InvokeVoidAsync("detachViewportOffsetObserver", _viewportAnchor);
            }
            catch
            {
            }

            try
            {
                await _layoutModule.DisposeAsync();
            }
            catch
            {
            }
        }

        _layoutCallbackRef?.Dispose();
    }

}