@page "/scrolls-carousel"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaCarousel</PageTitle>

<div class="docs-page">
    <h1>SkiaCarousel</h1>
    <p class="docs-lead">SkiaCarousel is a snapping scroll surface for swipeable pages, galleries, and cards. 
        You can set content directly or use `ItemsSource` for data binding.</p>
    <p class="docs-note">Swipe the cards. The selected index label follows the active slide.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" 
                WidthRequest="360"
                HeightRequest="420"
                BackgroundColor="@Color.Parse("#F6F0E6")"
                Margin="0,8,0,0"
                RenderingMode="@RenderingModeType.Accelerated"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@CarouselSnippet</code></pre>
</div>

@code {
    private const string CarouselSnippet = """
var carousel = new SkiaCarousel()
{
    Spacing = 8,
    SelectedIndex = 0,
    IsLooped = true
};
""";

    private readonly SkiaCarousel _carousel;
    private readonly SkiaLabel _statusLabel;
    private SkiaControl _canvasContent;

    public ScrollsCarousel()
    {
        _statusLabel = new SkiaLabel()
        {
            Text = "Slide 1 / 4",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Start
        };

        _carousel = new SkiaCarousel()
        {
            HorizontalOptions = LayoutOptions.Fill,
            VerticalOptions = LayoutOptions.Fill,
            Spacing = 8,
            SelectedIndex = 0,
            IsLooped = true,
            Children =
            {
                CreateSlide("Launch notes", "Swipeable cards land better when each state feels authored instead of placeholder.", "Preview", "Snap", new Color(0.914f, 0.271f, 0.376f, 1f)),
                CreateSlide("Review queue", "Keep neighbor cards peeking in without letting them steal the center focus.", "Queue", "Offset", new Color(0.059f, 0.204f, 0.376f, 1f)),
                CreateSlide("Signals", "Snapping should commit to a full card state instead of a mushy midpoint.", "State", "Focus", new Color(0.325f, 0.204f, 0.514f, 1f)),
                CreateSlide("Handoff", "Buttons and swipe gestures can steer the same selected index without drift.", "Dual", "Input", new Color(0.659f, 0.875f, 0.557f, 1f), new Color(0.102f, 0.102f, 0.180f, 1f))
            }
        };

        _carousel.SelectedIndexChanged += OnSelectedIndexChanged;

        _canvasContent = new SkiaLayer()
        {
            Margin = new Thickness(16),
            Padding = new Thickness(20),
            VerticalOptions = LayoutOptions.Fill,
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Spacing = 14,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaCarousel",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Margin = new Thickness(0,40,0,0),
                    Text = "Swipe or tap through authored slides with visible side peeks.",
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    WidthRequest = 248
                },
                
                _carousel.WithMargin(0,90,0,30),

                _statusLabel.WithVerticalOptions(LayoutOptions.End)
            }
        };
    }

    private void OnSelectedIndexChanged(object? sender, int index)
    {
        _statusLabel.Text = $"Slide {index + 1} / {_carousel.ChildrenCount}";
    }

    private static SkiaShape CreateSlide(string title, string body, string chipOne, string chipTwo, Color backgroundColor, Color? textColor = null)
    {
        return new SkiaShape()
        {
            Type = ShapeType.Rectangle,
            CornerRadius = 24,
            BackgroundColor = backgroundColor,
            UseCache = SkiaCacheType.Image,
            Children =
            {
                new SkiaLayout()
                {
                    Padding = new Thickness(18, 18, 18, 16),
                    Type = LayoutType.Column,
                    Spacing = 10,
                    HorizontalOptions = LayoutOptions.Fill,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaShape()
                        {
                            WidthRequest = 58,
                            HeightRequest = 24,
                            Type = ShapeType.Rectangle,
                            CornerRadius = 99,
                            BackgroundColor = new Color(1f, 1f, 1f, 0.24f),
                            Children =
                            {
                                new SkiaLabel()
                                {
                                    Text = "Deck",
                                    FontFamily = "FontTextTitle",
                                    FontSize = 11,
                                    TextColor = textColor ?? Colors.White,
                                    HorizontalOptions = LayoutOptions.Center,
                                    VerticalOptions = LayoutOptions.Center
                                }
                            }
                        },
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 22,
                            TextColor = textColor ?? Colors.White,
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        new SkiaLabel()
                        {
                            Text = body,
                            FontFamily = "FontText",
                            FontSize = 13,
                            TextColor = textColor ?? new Color(1f, 1f, 1f, 0.92f),
                            HorizontalOptions = LayoutOptions.Fill,
                            WidthRequest = 214
                        },
                        new SkiaLayout()
                        {
                            Type = LayoutType.Row,
                            Spacing = 8,
                            Children =
                            {
                                CreateMetaChip(chipOne, textColor),
                                CreateMetaChip(chipTwo, textColor)
                            }
                        }
                    }
                }
            }
        };
    }

    private static SkiaShape CreateMetaChip(string text, Color? textColor)
    {
        return new SkiaShape()
        {
            UseCache = SkiaCacheType.Operations,
            WidthRequest = 72,
            HeightRequest = 24,
            Type = ShapeType.Rectangle,
            CornerRadius = 99,
            BackgroundColor = new Color(1f, 1f, 1f, 0.22f),
            Children =
            {
                new SkiaLabel()
                {
                    Text = text,
                    FontFamily = "FontTextTitle",
                    FontSize = 10,
                    TextColor = textColor ?? Colors.White,
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}