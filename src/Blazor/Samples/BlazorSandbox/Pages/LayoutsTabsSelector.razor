@page "/layouts-tabs-selector"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaTabsSelector</PageTitle>

<div class="docs-page">
    <h1>SkiaTabsSelector</h1>
    <p class="docs-lead">SkiaTabsSelector treats a chosen child type as a selectable tab row. It is the lightest way to coordinate tab selection state before you attach the chosen index to a carousel, a view switcher, or another drawn surface.</p>
    <p class="docs-note">Tap the labels in the tab strip. The selector updates the selected index and this demo recolors the active tab to make the state obvious.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" 
                WidthRequest="360"
                BackgroundColor="@Color.Parse("#F6F0E6")"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@TabsSnippet</code></pre>
</div>

@code {
    private const string TabsSnippet = """
var tabs = new SkiaTabsSelector()
{
    SelectedIndex = 0,
    Children = { tabOne, tabTwo, tabThree }
};
""";

    private readonly DemoTabsSelector _tabs;
    private readonly SkiaShape _detailCard;
    private readonly SkiaLabel _detailTitle;
    private readonly SkiaLabel _detailBody;
    private readonly SkiaLabel _statusLabel;
    private readonly SkiaShape _tabsShell;
    private SkiaControl _canvasContent;

    public LayoutsTabsSelector()
    {
        _detailTitle = new SkiaLabel()
        {
            Text = "Summary",
            FontFamily = "FontTextTitle",
            FontSize = 19,
            TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };

        _detailBody = new SkiaLabel()
        {
            Text = "The current tab can drive a sibling surface without adding heavy shell logic.",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            WidthRequest = 230
        };

        _detailCard = new SkiaShape()
        {
            HeightRequest = 108,
            Type = ShapeType.Rectangle,
            CornerRadius = 18,
            BackgroundColor = new Color(0.918f, 0.941f, 0.976f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                new SkiaStack()
                {
                    Padding = new Thickness(16, 16, 16, 14),
                    Spacing = 8,
                    Children =
                    {
                        _detailTitle,
                        _detailBody
                    }
                }
            }
        };

        _statusLabel = new SkiaLabel()
        {
            Text = "Selected tab: Demo",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Start
        };

        var tabs = new List<TabVisual>
        {
            CreateTabVisual("Demo", 0),
            CreateTabVisual("About", 1)
        };

        _tabs = new DemoTabsSelector(tabs, OnTabChanged)
        {
            HorizontalOptions = LayoutOptions.Fill,
            HeightRequest = 48,
            TabType = typeof(SkiaLabel),
            BackgroundColor = Colors.Transparent,
            Type = LayoutType.Grid,
            ColumnDefinitions = new ColumnDefinitionCollection
            {
                new ColumnDefinition(GridLength.Star),
                new ColumnDefinition(GridLength.Star)
            },
            RowDefinitions = new RowDefinitionCollection
            {
                new RowDefinition(GridLength.Star)
            },
            ColumnSpacing = 0,
            Padding = new Thickness(0),
            SelectedIndex = 0,
            Children = tabs.Select(x => (SkiaControl)x.Label).ToList()
        };

        Grid.SetColumn(tabs[1].Label, 1);

        var indicatorStrip = new SkiaLayout()
        {
            HeightRequest = 4,
            Type = LayoutType.Grid,
            ColumnDefinitions = new ColumnDefinitionCollection
            {
                new ColumnDefinition(GridLength.Star),
                new ColumnDefinition(GridLength.Star)
            },
            ColumnSpacing = 0,
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                tabs[0].Indicator,
                tabs[1].Indicator
            }
        };

        Grid.SetColumn(tabs[1].Indicator, 1);

        _tabsShell = new SkiaShape()
        {
            HeightRequest = 72,
            Type = ShapeType.Rectangle,
            CornerRadius = 20,
            BackgroundColor = new Color(0.090f, 0.118f, 0.188f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                new SkiaLayout()
                {
                    Padding = new Thickness(12, 12, 12, 12),
                    Type = LayoutType.Column,
                    HorizontalOptions = LayoutOptions.Fill,
                    VerticalOptions = LayoutOptions.Center,
                    Spacing = 8,
                    Children =
                    {
                        _tabs,
                        indicatorStrip
                    }
                }
            }
        };

        _tabs.ApplyVisualState();

    ApplyDetailState(0, "Demo");

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            HorizontalOptions = LayoutOptions.Fill,
            Padding = new Thickness(20),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 14,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaTabsSelector",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _tabsShell,
                _statusLabel,
                _detailCard,
                new SkiaLabel()
                {
                    Text = "In larger samples, this selected index usually drives a carousel or view-switching surface.",
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    WidthRequest = 248
                }
            }
        };
    }

    private TabVisual CreateTabVisual(string text, int index)
    {
        var label = new SkiaLabel()
        {
            FontFamily = "FontTextTitle",
            FontSize = 14,
            Text = text,
            TextColor = Colors.White,
            HorizontalOptions = LayoutOptions.Center,
            VerticalOptions = LayoutOptions.Center,
            HorizontalTextAlignment = DrawTextAlignment.Center
        };

        var indicator = new SkiaShape()
        {
            WidthRequest = 48,
            HeightRequest = 4,
            Type = ShapeType.Rectangle,
            CornerRadius = 99,
            BackgroundColor = new Color(0.808f, 0.439f, 0.220f, 1f),
            HorizontalOptions = LayoutOptions.Center,
            VerticalOptions = LayoutOptions.End,
            Opacity = 0
        };

        label.Tapped += (_, _) => _tabs?.SelectedIndex = index;

        return new TabVisual(text, label, indicator);
    }

    private void OnTabChanged(int index, string text)
    {
        _statusLabel.Text = $"Selected tab: {text}";
        ApplyDetailState(index, text);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplyDetailState(int index, string text)
    {
        _detailTitle.Text = text;

        switch (index)
        {
            case 0:
                _detailCard.BackgroundColor = new Color(0.918f, 0.941f, 0.976f, 1f);
                _detailBody.Text = "Demo mode keeps the selector lightweight while it still drives a sibling drawn surface.";
                break;
            default:
                _detailCard.BackgroundColor = new Color(0.961f, 0.925f, 0.898f, 1f);
                _detailBody.Text = "About mode can swap supporting content without rebuilding the surrounding frame.";
                break;
        }
    }

    private sealed class DemoTabsSelector : SkiaTabsSelector
    {
        private readonly IReadOnlyList<TabVisual> _tabs;
        private readonly Action<int, string> _onChanged;

        public DemoTabsSelector(IReadOnlyList<TabVisual> tabs, Action<int, string> onChanged)
        {
            _tabs = tabs;
            _onChanged = onChanged;
        }

        public void ApplyVisualState()
        {
            for (var index = 0; index < _tabs.Count; index++)
            {
                var active = index == SelectedIndex;
                _tabs[index].Label.Opacity = active ? 1 : 0.66;
                _tabs[index].Indicator.Opacity = active ? 1 : 0;
            }
        }

        public override async Task OnTabSelectionChanged(bool tabsChanged, int index)
        {
            await base.OnTabSelectionChanged(tabsChanged, index);
            ApplyVisualState();

            if (index >= 0 && index < _tabs.Count)
            {
                _onChanged(index, _tabs[index].Text);
            }
        }
    }

    private sealed class TabVisual
    {
        public TabVisual(string text, SkiaLabel label, SkiaShape indicator)
        {
            Text = text;
            Label = label;
            Indicator = indicator;
        }

        public string Text { get; }

        public SkiaLabel Label { get; }

        public SkiaShape Indicator { get; }
    }
}