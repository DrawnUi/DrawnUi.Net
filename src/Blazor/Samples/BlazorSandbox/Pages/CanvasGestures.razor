@page "/canvas-gestures"
@using AppoMobi.Gestures
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>Canvas Gestures</PageTitle>

<div class="docs-page">
    <h1>Canvas Gestures</h1>
    <p class="docs-lead">This page shows how pointer, wheel, tap, and drag input enters DrawnUI through <strong>Canvas</strong> in Blazor. The goal is to keep the gesture model visible without dropping into a low-level interop sample.</p>
    <p class="docs-note">Under the hood DrawnUI.Blazor is backed by <strong>AppoMobi.Blazor.Gestures</strong>, but the API you usually touch here is <strong>Canvas</strong>, <strong>GesturesMode</strong>, and gesture events on drawn controls. This demo keeps everything inside one surface: tap anywhere, drag the amber block, and move or wheel over the same pad.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent"
                WidthRequest="400"
                BackgroundColor="#FFF5E8"
                Margin="0,16,0,0"
                RenderingMode="@RenderingModeType.Accelerated"
                Gestures="@GesturesMode.Lock" />
    </div>

    <pre class="docs-code"><code>@GestureSnippet</code></pre>
</div>

@code {
    private const float DragStartX = 20f;
    private const float DragStartY = 132f;
    private const float DragSize = 120f;

    private const string GestureSnippet = """
<Canvas Content="_canvasContent"
        WidthRequest="400"
        HeightRequest="700"
        Gestures="@GesturesMode.Enabled" />

gesturePad.Tapped += OnGesturePadTapped;
gesturePad.ConsumeGestures += OnGesturePadGestures;

_isDraggingBlock = _dragTarget.HitIsInside(
    e.Args.Event.Location.X,
    e.Args.Event.Location.Y);

var scale = Math.Max(_dragTarget.RenderingScale, 1f);
_dragTarget.TranslationX += e.Args.Event.Distance.Delta.X / scale;
_dragTarget.TranslationY += e.Args.Event.Distance.Delta.Y / scale;
""";


    public class CheckMe : SkiaLayer
    {
        public override ScaledSize OnMeasuring(float widthConstraint, float heightConstraint, float scale)
        {
            var ret = base.OnMeasuring(widthConstraint, heightConstraint, scale);

            return ret;
        }
    }

    private readonly SkiaLabel _heroLabel = new()
    {
        Text = "Canvas gestures ready",
        FontFamily = "FontTextTitle",
        FontSize = 26,
        TextColor = new Color(0.145f, 0.169f, 0.216f, 1f),
        HorizontalOptions = LayoutOptions.Fill,
        UseCache = SkiaCacheType.Operations,
    };

    private readonly SkiaLabel _gestureStatus = new()
    {
        IsParentIndependent = true,
        UseCache = SkiaCacheType.Operations,
        Text = "Gesture pad: waiting",
        FontFamily = "FontText",
        FontSize = 14,
        TextColor = new Color(0.220f, 0.247f, 0.286f, 1f),
        HorizontalOptions = LayoutOptions.Fill
    };

    private readonly SkiaLabel[] _historyLabels =
    {
        CreateHistoryLabel(),
        CreateHistoryLabel(),
        CreateHistoryLabel(),
        CreateHistoryLabel()
    };

    private readonly List<string> _history =
    [
        "Waiting for gestures",
        "Waiting for gestures",
        "Waiting for gestures",
        "Waiting for gestures"
    ];

    private readonly SkiaShape _dragTarget = new()
    {
        UseCache = SkiaCacheType.GPU,
        WidthRequest = DragSize,
        HeightRequest = DragSize,
        Type = ShapeType.Rectangle,
        BackgroundColor = new Color(0.992f, 0.819f, 0.490f, 1f),
        StrokeColor = new Color(0.529f, 0.302f, 0.094f, 1f),
        StrokeWidth = 2,
        CornerRadius = 18,
        TranslationX = DragStartX,
        TranslationY = DragStartY,
        HorizontalOptions = LayoutOptions.Start,
        VerticalOptions = LayoutOptions.Start,
        Children =
        {
            new SkiaLabel()
            {
                Text = "Drag me",
                FontFamily = "FontTextTitle",
                FontSize = 18,
                TextColor = new Color(0.357f, 0.204f, 0.047f, 1f),
                HorizontalOptions = LayoutOptions.Center,
                VerticalOptions = LayoutOptions.Center
            }
        }
    };

    private readonly SkiaShape _gesturePad;

    private readonly SkiaControl _canvasContent;
    private bool _isDraggingBlock;

    public CanvasGestures()
    {
        _gesturePad = new SkiaShape()
        {
            HorizontalOptions = LayoutOptions.Fill,
            HeightRequest = 340,
            Type = ShapeType.Rectangle,
            BackgroundColor = new Color(0.961f, 0.929f, 0.855f, 1f),
            StrokeColor = new Color(0.851f, 0.827f, 0.776f, 1f),
            StrokeWidth = 1,
            CornerRadius = 18,
            Padding = new Thickness(16),
            Children =
            {
                new SkiaLayer()
                {
                    Children =
                    {
                        new CheckMe()
                        {
                            UseCache = SkiaCacheType.Image,
                            Children =
                            {
                                new SkiaLabel()
                                {
                                    IsParentIndependent = true,
                                    UseCache = SkiaCacheType.Operations,
                                    Text = "Gesture pad",
                                    FontFamily = "FontTextTitle",
                                    FontSize = 18,
                                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                                    HorizontalOptions = LayoutOptions.Fill
                                },
                                new SkiaLabel()
                                {
                                    UseCache = SkiaCacheType.Operations,
                                    IsParentIndependent = true,
                                    Text = "Tap anywhere, drag the amber block, and use pointer or wheel on the same surface.",
                                    FontFamily = "FontText",
                                    FontSize = 14,
                                    TextColor = new Color(0.388f, 0.435f, 0.502f, 1f),
                                    HorizontalOptions = LayoutOptions.Fill,
                                    Margin = new Thickness(0, 32, 0, 0)
                                },
                                new SkiaShape()
                                {
                                    UseCache = SkiaCacheType.Operations,
                                    HorizontalOptions = LayoutOptions.Fill,
                                    HeightRequest = 188,
                                    Type = ShapeType.Rectangle,
                                    BackgroundColor = new Color(0.157f, 0.216f, 0.322f, 1f),
                                    StrokeColor = new Color(0.424f, 0.518f, 0.639f, 1f),
                                    StrokeWidth = 1,
                                    CornerRadius = 18,
                                    Margin = new Thickness(0, 96, 0, 0)
                                },
                            }
                        },
                       
                        _dragTarget
                    }
                }
            }
        };

        _gesturePad.Tapped += OnGesturePadTapped;
        _gesturePad.ConsumeGestures += OnGesturePadGestures;

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            HorizontalOptions = LayoutOptions.Fill,
            Padding = new Thickness(18),
            BackgroundColor = new Color(0.996f, 0.992f, 0.965f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                _heroLabel,

                new SkiaLabel()
                {
                    UseCache = SkiaCacheType.Operations,
                    Text = "Canvas gestures are enabled on this surface. Tap, drag, pointer hover, and wheel input all stay inside the DrawnUI event pipeline.",
                    FontFamily = "FontText",
                    FontSize = 14,
                    TextColor = new Color(0.388f, 0.435f, 0.502f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },

                _gesturePad,

                _gestureStatus,

                new SkiaLayout()
                {
                    IsParentIndependent = true,
                    UseCache = SkiaCacheType.Operations,
                    HorizontalOptions = LayoutOptions.Fill,
                    Padding = new Thickness(14),
                    BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
                    Type = LayoutType.Column,
                    Spacing = 8,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = "Recent events",
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        _historyLabels[0],
                        _historyLabels[1],
                        _historyLabels[2],
                        _historyLabels[3]
                    }
                }
            }
        };
    }

    private void OnGesturePadTapped(object? sender, ControlTappedEventArgs e)
    {
        _heroLabel.Text = "Canvas gestures live";
        _gestureStatus.Text = $"Gesture pad: tapped at {e.Parameters.Event.Location.X:0},{e.Parameters.Event.Location.Y:0}";
        PushHistory($"Tapped {e.Parameters.Event.Location.X:0},{e.Parameters.Event.Location.Y:0}");
    }

    private void OnGesturePadGestures(object? sender, SkiaGesturesInfo e)
    {
        if (e.Args.Type == TouchActionResult.Pointer)
        {
            _gestureStatus.Text = $"Gesture pad: pointer at {e.Args.Event.Location.X:0},{e.Args.Event.Location.Y:0}";
        }
        else if (e.Args.Type == TouchActionResult.Down)
        {
            _isDraggingBlock = _dragTarget.HitIsInside(
                e.Args.Event.Location.X,
                e.Args.Event.Location.Y);
            _gestureStatus.Text = _isDraggingBlock
                ? "Gesture pad: drag block and move"
                : $"Gesture pad: down at {e.Args.Event.Location.X:0},{e.Args.Event.Location.Y:0}";
            PushHistory(_isDraggingBlock ? "Drag down" : $"Down {e.Args.Event.Location.X:0},{e.Args.Event.Location.Y:0}");
        }
        else if (e.Args.Type == TouchActionResult.Panning)
        {
            if (_isDraggingBlock)
            {
                var scale = Math.Max(_dragTarget.RenderingScale, 1f);
                _dragTarget.TranslationX += e.Args.Event.Distance.Delta.X / scale;
                _dragTarget.TranslationY += e.Args.Event.Distance.Delta.Y / scale;
                _gestureStatus.Text = $"Gesture pad: drag dx {e.Args.Event.Distance.Delta.X:0}, dy {e.Args.Event.Distance.Delta.Y:0}";
                e.Consumed = true;
            }
            else
            {
                _gestureStatus.Text = $"Gesture pad: panning dx {e.Args.Event.Distance.Delta.X:0}, dy {e.Args.Event.Distance.Delta.Y:0}";
            }
        }
        else if (e.Args.Type == TouchActionResult.Up)
        {
            _gestureStatus.Text = _isDraggingBlock
                ? $"Gesture pad: block released at {_dragTarget.TranslationX:0},{_dragTarget.TranslationY:0}"
                : $"Gesture pad: up at {e.Args.Event.Location.X:0},{e.Args.Event.Location.Y:0}";
            PushHistory(_isDraggingBlock
                ? $"Drag up {_dragTarget.TranslationX:0},{_dragTarget.TranslationY:0}"
                : $"Up {e.Args.Event.Location.X:0},{e.Args.Event.Location.Y:0}");
            _isDraggingBlock = false;
        }
        else if (e.Args.Type == TouchActionResult.Wheel && e.Args.Event.Wheel is not null)
        {
            _gestureStatus.Text = $"Gesture pad: wheel {e.Args.Event.Wheel.Delta:0} at {e.Args.Event.Wheel.Center.X:0},{e.Args.Event.Wheel.Center.Y:0}";
            PushHistory($"Wheel {e.Args.Event.Wheel.Delta:0}");
            e.Consumed = true;
        }

        RequestRender();
    }

    private void PushHistory(string text)
    {
        _history.Insert(0, text);
        if (_history.Count > _historyLabels.Length)
        {
            _history.RemoveAt(_history.Count - 1);
        }

        for (var index = 0; index < _historyLabels.Length; index++)
        {
            _historyLabels[index].Text = _history[index];
        }

        RequestRender();
    }

    private void RequestRender()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static SkiaLabel CreateHistoryLabel()
    {
        return new SkiaLabel()
        {
            Text = "Waiting for gestures",
            FontFamily = "FontText",
            FontSize = 14,
            TextColor = new Color(0.255f, 0.286f, 0.353f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };
    }
}