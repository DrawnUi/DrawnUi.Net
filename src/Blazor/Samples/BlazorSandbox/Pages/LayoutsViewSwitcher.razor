@page "/layouts-view-switcher"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaViewSwitcher</PageTitle>

<div class="docs-page">
    <h1>SkiaViewSwitcher</h1>
    <p class="docs-lead">SkiaViewSwitcher shows one child view at a time and is a good fit for step flows, state pages, and shell-sized surface swaps where everything should remain drawn.</p>
    <p class="docs-note">Use the buttons to switch the active card. The example intentionally stays small and focuses on the selected view behavior.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@ViewSwitcherSnippet</code></pre>
</div>

@code {
    private const string ViewSwitcherSnippet = """
var switcher = new SkiaViewSwitcher()
{
    SelectedIndex = 0,
    Children = { firstView, secondView, thirdView }
};
""";

    private readonly SkiaViewSwitcher _switcher;
    private readonly SkiaLabel _statusLabel;
    private readonly List<SegmentVisual> _segments;
    private SkiaControl _canvasContent;

    public LayoutsViewSwitcher()
    {
        _segments = new();

        _statusLabel = new SkiaLabel()
        {
            Text = "Active view: Intro",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Start
        };

        _switcher = new SkiaViewSwitcher()
        {
            HorizontalOptions = LayoutOptions.Fill,
            HeightRequest = 188,
            SelectedIndex = 0,
            Children =
            {
                CreateSwitcherCard("Intro", "Keep one authored surface active while the rest of the flow stays offstage.", new Color(0.918f, 0.941f, 0.976f, 1f)),
                CreateSwitcherCard("Review", "Swap to an audit state without rebuilding the surrounding frame.", new Color(0.961f, 0.925f, 0.898f, 1f)),
                CreateSwitcherCard("Launch", "Promote the next view only when the sequence is ready to advance.", new Color(0.922f, 0.961f, 0.929f, 1f))
            }
        };

        _canvasContent = new SkiaStack()
        {
            Margin = new Thickness(16),
            Padding = new Thickness(20),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Spacing = 14,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaViewSwitcher",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _switcher,
                new SkiaShape()
                {
                    WidthRequest = 288,
                    HeightRequest = 152,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 18,
                    BackgroundColor = new Color(0.922f, 0.941f, 0.976f, 1f),
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        new SkiaLayout()
                        {
                            Padding = new Thickness(8),
                            WidthRequest = 288,
                            Type = LayoutType.Column,
                            Spacing = 8,
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center,
                            Children =
                            {
                                CreateSwitcherSegment("Intro", 0),
                                CreateSwitcherSegment("Review", 1),
                                CreateSwitcherSegment("Launch", 2)
                            }
                        }
                    }
                },
                _statusLabel
            }
        };

        ApplySegmentState(0);
    }

    private SkiaShape CreateSwitcherSegment(string text, int index)
    {
        var label = new SkiaLabel()
        {
            Text = text,
            FontFamily = "FontTextTitle",
            FontSize = 13,
            TextColor = new Color(0.224f, 0.255f, 0.345f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            VerticalOptions = LayoutOptions.Center,
            HorizontalTextAlignment = DrawTextAlignment.Start,
            Margin = new Thickness(16, 0, 0, 0)
        };

        var shape = new SkiaShape()
        {
            WidthRequest = 272,
            HeightRequest = 40,
            Type = ShapeType.Rectangle,
            CornerRadius = 14,
            BackgroundColor = new Color(1f, 1f, 1f, 0.55f),
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                label
            }
        };

        shape.Tapped += (_, _) =>
        {
            _switcher.SelectedIndex = index;
            _statusLabel.Text = $"Active view: {text}";
            ApplySegmentState(index);
            _ = InvokeAsync(StateHasChanged);
        };

        _segments.Add(new SegmentVisual(shape, label));

        return shape;
    }

    private void ApplySegmentState(int selectedIndex)
    {
        for (var index = 0; index < _segments.Count; index++)
        {
            var active = index == selectedIndex;
            _segments[index].Shape.BackgroundColor = active ? new Color(0.102f, 0.145f, 0.231f, 1f) : new Color(1f, 1f, 1f, 0.55f);
            _segments[index].Label.TextColor = active ? Colors.White : new Color(0.224f, 0.255f, 0.345f, 1f);
        }
    }

    private static SkiaShape CreateSwitcherCard(string title, string body, Color color)
    {
        return new SkiaShape()
        {
            WidthRequest = 292,
            HeightRequest = 188,
            Type = ShapeType.Rectangle,
            CornerRadius = 20,
            BackgroundColor = color,
            Children =
            {
                new SkiaLayout()
                {
                    Padding = new Thickness(18, 18, 18, 16),
                    Type = LayoutType.Column,
                    Spacing = 10,
                    Children =
                    {
                        new SkiaShape()
                        {
                            WidthRequest = 62,
                            HeightRequest = 24,
                            Type = ShapeType.Rectangle,
                            CornerRadius = 99,
                            BackgroundColor = new Color(1f, 1f, 1f, 0.45f),
                            Children =
                            {
                                new SkiaLabel()
                                {
                                    Text = "Active",
                                    FontFamily = "FontTextTitle",
                                    FontSize = 11,
                                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                                    HorizontalOptions = LayoutOptions.Center,
                                    VerticalOptions = LayoutOptions.Center
                                }
                            }
                        },
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 23,
                            TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        new SkiaLabel()
                        {
                            Text = body,
                            FontFamily = "FontText",
                            FontSize = 13,
                            TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                            HorizontalOptions = LayoutOptions.Fill,
                            WidthRequest = 238
                        }
                    }
                }
            }
        };
    }

    private sealed class SegmentVisual
    {
        public SegmentVisual(SkiaShape shape, SkiaLabel label)
        {
            Shape = shape;
            Label = label;
        }

        public SkiaShape Shape { get; }

        public SkiaLabel Label { get; }
    }
}