<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

<PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  <DefineConstants>$(DefineConstants);SKIPMESH</DefineConstants>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
    <ServiceWorkerAssetsManifest>service-worker-assets.js</ServiceWorkerAssetsManifest>
    <WasmBuildNative>true</WasmBuildNative>

    <!-- use nugets or ref drawnui source-->
    <UseSource>true</UseSource>

</PropertyGroup>

<ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.7" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.7" PrivateAssets="all" />
</ItemGroup>

<ItemGroup Condition="'$(UseSource)' != 'true'">
    <PackageReference Include="DrawnUi.Blazor.Game" Version="1.10.4.1" />
</ItemGroup>

<ItemGroup Condition="'$(UseSource)' == 'true'">
  <ProjectReference Include="..\..\DrawnUi.Wasm\DrawnUi.Blazor.Wasm.csproj" />
  <ProjectReference Include="..\..\Addons\DrawnUi.Blazor.Game\DrawnUi.Blazor.Game.csproj" />
</ItemGroup>

  <!-- Shared Pong game code (PongGame, AI, sprites, RescalingCanvas) -->
    <Import Project="..\..\..\Shared\Samples\Pong.Shared\Pong.Shared.projitems" Label="Shared" />

  <ItemGroup>
    <ServiceWorker Include="wwwroot\service-worker.js" PublishedContent="wwwroot\service-worker.published.js" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootAssembly Include="SkiaSharp" />
  </ItemGroup>

  <ItemGroup Condition="$([System.String]::Copy('$(DefineConstants)').Contains('SKIPMESH'))">
    <RazorComponent Remove="Pages\SKMesh*.*" />
    <Content Remove="Pages\SKMesh*.*" />
    <None Remove="Pages\SKMesh*.*" />
  </ItemGroup>

</Project>
