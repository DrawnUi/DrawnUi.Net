@implements IDisposable
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Routing

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <div class="navbar-brand-wrap">
            <a class="navbar-brand" href="">DrawnUI Blazor Sandbox</a>
        </div>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav flex-column">
        @foreach (var section in NavMenuItems.RootSections)
        {
            <NavMenuSectionView Section="section"
                                IsExpanded="IsSectionExpanded(section.Key)"
                                IsSectionExpanded="IsSectionExpanded"
                                ToggleSection="ToggleSection"
                                CloseNavMenu="CloseNavMenu" />
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private readonly HashSet<string> expandedSections = NavMenuItems.CreateDefaultExpandedSections();

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        ExpandSectionsForUri(NavigationManager.Uri);
    }

    private bool IsSectionExpanded(string key)
    {
        return expandedSections.Contains(key);
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private Task ToggleSection(string key)
    {
        if (!expandedSections.Add(key))
        {
            expandedSections.Remove(key);
        }

        return Task.CompletedTask;
    }

    private void CloseNavMenu(MouseEventArgs _)
    {
        collapseNavMenu = true;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        ExpandSectionsForUri(args.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ExpandSectionsForUri(string absoluteUri)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(absoluteUri);
        foreach (var sectionKey in NavMenuItems.FindSectionPathForHref(relativePath))
        {
            expandedSections.Add(sectionKey);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
