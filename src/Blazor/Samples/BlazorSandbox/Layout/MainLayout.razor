@inherits LayoutComponentBase
@if (!IsUnderConstruction)
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4">
                <div class="top-row-copy">
                    <span class="top-row-pill">Public preview</span>
                    <span class="top-row-text">Using SkiaSharp 4.147.0-preview.2.1</span>
                </div>

                <div class="top-row-links">
                    <a href="https://github.com/taublast/DrawnUi" target="_blank" rel="noreferrer">GitHub</a>
                </div>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
}
else
{
    <div class="page page-release-placeholder">
        <main class="release-placeholder-main">
            <section class="release-placeholder-card" aria-labelledby="release-placeholder-title">
                <span class="release-placeholder-kicker">DrawnUI Blazor Sandbox</span>
                <h1 id="release-placeholder-title">Fixing Bugs, Coming Soon...</h1>
                <p>The public sandbox content is hidden for non-debug builds while work continues behind the scenes.</p>
            </section>
        </main>
    </div>
}

@code {
#if DEBUG
    private const bool IsUnderConstruction = false;
#else
    private const bool IsUnderConstruction = false;
#endif
}
