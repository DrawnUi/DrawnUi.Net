@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-copy">
                <span class="top-row-pill">Public preview</span>
                <span class="top-row-text">Rendering Engine for .NET powered by SkiaSharp.</span>
            </div>

            <div class="top-row-links">
                <a href="https://github.com/taublast/DrawnUi" target="_blank" rel="noreferrer">GitHub</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
