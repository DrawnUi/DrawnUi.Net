@namespace DrawnUi.Views
@implements IAsyncDisposable
@inject IJSRuntime JS
@using Microsoft.JSInterop

<div @ref="_hostElement" class="@HostClass" style="@HostStyle">
    @ChildContent
</div>

@code {
    private const string ViewportModulePath = "./_content/DrawnUi.Blazor.Core/drawnui-viewport-host.js";

    /// <summary>
    /// Logical content width used to preserve the embedded host aspect ratio.
    /// </summary>
    [Parameter]
    public float AspectWidth { get; set; }

    /// <summary>
    /// Logical content height used to preserve the embedded host aspect ratio.
    /// </summary>
    [Parameter]
    public float AspectHeight { get; set; }

    /// <summary>
    /// Background color applied to both embedded and fullscreen host modes.
    /// </summary>
    [Parameter]
    public string BackgroundColor { get; set; } = "#000000";

    /// <summary>
    /// Switches the host from embedded mode into a fixed fullscreen overlay.
    /// </summary>
    [Parameter]
    public bool IsFullscreen { get; set; }

    /// <summary>
    /// In embedded mode, limits the host by the visible browser height instead of filling page width.
    /// </summary>
    [Parameter]
    public bool FitVisibleHeight { get; set; }

    /// <summary>
    /// Reserved vertical chrome in pixels when <see cref="FitVisibleHeight"/> is enabled.
    /// </summary>
    [Parameter]
    public float ViewportOffsetPixels { get; set; }

    /// <summary>
    /// Embedded mode margin. Fullscreen mode always resets margin to zero.
    /// </summary>
    [Parameter]
    public string EmbeddedMargin { get; set; } = "16px auto 32px";

    /// <summary>
    /// Fullscreen z-index for the fixed overlay host.
    /// </summary>
    [Parameter]
    public int FullscreenZIndex { get; set; } = 2000;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private ElementReference _hostElement;
    private IJSObjectReference? _viewportModule;
    private DotNetObjectReference<AspectLockedViewportHost>? _viewportCallbackRef;
    private float _measuredViewportOffsetPixels;
    private bool _viewportObserverAttached;
    private bool ShouldObserveViewportOffset => FitVisibleHeight && !IsFullscreen;
    private float EffectiveViewportOffsetPixels => ViewportOffsetPixels > 0f
        ? ViewportOffsetPixels
        : _measuredViewportOffsetPixels;

    private string HostClass => IsFullscreen
        ? "aspect-locked-host fullscreen"
        : FitVisibleHeight
            ? "aspect-locked-host fit-height"
            : "aspect-locked-host fit-width";

    private string HostStyle
    {
        get
        {
            var aspectRatio = AspectHeight > 0f
                ? AspectWidth / AspectHeight
                : 1f;

            return FormattableString.Invariant(
                $"--host-aspect: {AspectWidth} / {AspectHeight}; --host-aspect-ratio: {aspectRatio}; --host-background: {BackgroundColor}; --host-margin: {EmbeddedMargin}; --host-viewport-offset: {EffectiveViewportOffsetPixels}px; --host-z-index: {FullscreenZIndex};");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (ShouldObserveViewportOffset)
        {
            _viewportModule ??= await JS.InvokeAsync<IJSObjectReference>("import", ViewportModulePath);
            _viewportCallbackRef ??= DotNetObjectReference.Create(this);

            if (!_viewportObserverAttached)
            {
                await _viewportModule.InvokeVoidAsync("attachViewportOffsetObserver", _hostElement, _viewportCallbackRef);
                _viewportObserverAttached = true;
            }
            else
            {
                await _viewportModule.InvokeVoidAsync("refreshViewportOffset", _hostElement);
            }

            return;
        }

        if (_viewportObserverAttached && _viewportModule != null)
        {
            await _viewportModule.InvokeVoidAsync("detachViewportOffsetObserver", _hostElement);
            _viewportObserverAttached = false;
        }
    }

    [JSInvokable]
    public async Task OnViewportOffsetChanged(double offset)
    {
        var nextOffset = (float)Math.Max(0, Math.Round(offset));
        if (Math.Abs(_measuredViewportOffsetPixels - nextOffset) < 0.5f)
            return;

        _measuredViewportOffsetPixels = nextOffset;
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_viewportModule != null)
        {
            if (_viewportObserverAttached)
            {
                try
                {
                    await _viewportModule.InvokeVoidAsync("detachViewportOffsetObserver", _hostElement);
                }
                catch
                {
                }
            }

            try
            {
                await _viewportModule.DisposeAsync();
            }
            catch
            {
            }
        }

        _viewportCallbackRef?.Dispose();
    }
}