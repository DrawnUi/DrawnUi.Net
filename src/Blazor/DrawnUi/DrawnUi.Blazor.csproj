<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoDefaultLaunchSettingsFile>true</NoDefaultLaunchSettingsFile>
    <StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>
    <PackageId>DrawnUi.Blazor.Core</PackageId>
    <Title>DrawnUI for Blazor Core</Title>
    <Description>Core implementation foundation for DrawnUI Blazor runtimes.</Description>
    <PackageTags>drawnui blazor core skia skiasharp</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Controls\**" />
    <Content Remove="Controls\**" />
    <EmbeddedResource Remove="Controls\**" />
    <None Remove="Controls\**" />
  </ItemGroup>

    <ItemGroup>
        <SupportedPlatform Include="browser" />
    </ItemGroup>

    <PropertyGroup>
        <DefineConstants>$(DefineConstants);ONPLATFORM;BROWSER;NET;NET10</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
    
      <PackageReference Include="AppoMobi.Blazor.Gestures" Version="3.10.6" />
    
      <PackageReference Include="AppoMobi.Specials" Version="10.0.2" />
        <PackageReference Include="CommonMark.NET" Version="0.15.1" />
        <PackageReference Include="HarfBuzzSharp.NativeAssets.WebAssembly" Version="14.2.0" />

      <PackageReference Include="SkiaSharp.HarfBuzz" Version="4.148.0" />
      <PackageReference Include="Svg.Skia" Version="4.9.0" />
    
      <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.7" />

    <PackageReference Include="SkiaSharp.Views.Blazor" Version="4.148.0" />
        <PackageReference Include="SkiaSharp.Skottie" Version="4.148.0" />

  </ItemGroup>

 
  <Import Project="..\..\Shared\DrawnUi\Shared.projitems" Label="Shared" />
  <Import Project="..\..\SharedNet\SharedNet.projitems" Label="SharedNet" />

  <ItemGroup>
    <Compile Remove="$(MSBuildThisFileDirectory)..\..\Shared\Features\Pdf\Pdf.cs" />
    <Compile Remove="$(MSBuildThisFileDirectory)..\..\Shared\Draw\Base\VisualTreeHandler.cs" />
    <!-- Parked MAUI-only repro copies, not compilable outside MAUI -->
    <Compile Remove="$(MSBuildThisFileDirectory)..\..\Shared\DrawnUi\Draw\Layout\OldRepro\**\*.cs" />
  </ItemGroup>

 


</Project>
