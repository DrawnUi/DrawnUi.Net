@namespace DrawnUi.Blazor.Server.Views
@using AppoMobi.Gestures
@using DrawnUi.Draw
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using PointF = System.Drawing.PointF
@implements IAsyncDisposable
@inject DrawnUi.Blazor.Server.IDrawnUiServerFrameEncoder FrameEncoder
@inject IJSRuntime JSRuntime

@if (ResolvedContent is null)
{
    <div>No DrawnUI content was provided.</div>
}
else if (string.IsNullOrWhiteSpace(_imageSource))
{
    <div>Rendering DrawnUI server frame...</div>
}
else
{
    <div @ref="_hostElement"
         style="position:relative; display:inline-block; overflow:hidden; max-width:100%; border-radius:12px; border:1px solid #d8c6a8;">
        <img @ref="_imageElement"
             src="@_imageSource"
             alt="@Alt"
             width="@_renderedWidth"
             height="@_renderedHeight"
             style="@Style"
             @onpointerdown="HandlePointerDownAsync"
             @onpointerup="HandlePointerUpAsync"
             @onpointerleave="HandlePointerLeaveAsync"
             @onpointercancel="HandlePointerLeaveAsync" />
    </div>
}

@code {
    private const long PointerId = 1;
    private const int DefaultAutoMeasureExtent = 1200;
    private const int MaxAutoMeasurePasses = 4;
    private DrawnUi.Blazor.Server.HeadlessCanvasHost? _host;
    private ElementReference _hostElement;
    private ElementReference _imageElement;
    private string? _imageSource;
    private IJSObjectReference? _module;
    private ISkiaGestureListener? _activeGestureListener;
    private bool _needsJsModule;
    private bool _pointerIsDown;
    private PointF _pointerDownLocation;
    private float _displayWidth;
    private float _displayHeight;
    private int _renderedWidth;
    private int _renderedHeight;
    private Color _renderedBackgroundColor = Colors.Transparent;

    private SkiaControl? ResolvedContent => Content ?? RootControl;

    [Parameter]
    public SkiaControl? Content { get; set; }

    [Parameter]
    public SkiaControl? RootControl { get; set; }

    [Parameter]
    public int Width { get; set; } = 400;

    [Parameter]
    public int? WidthRequest { get; set; }

    [Parameter]
    public int? Height { get; set; }

    [Parameter]
    public int? HeightRequest { get; set; }

    [Parameter]
    public string Alt { get; set; } = "DrawnUI server-rendered content";

    [Parameter]
    public string Style { get; set; } = "display:block; max-width:100%;";

    [Parameter]
    public Color BackgroundColor { get; set; } = Colors.Transparent;

    protected override async Task OnParametersSetAsync()
    {
        if (ResolvedContent is null)
        {
            await DisposeHostAsync();
            _imageSource = null;
            return;
        }

        var renderSize = ResolveRenderSize();
        EnsureHost(renderSize.Width, renderSize.Height);
        _host!.Canvas.Children = new List<SkiaControl> { ResolvedContent };
        await RenderFrameAsync();
        _needsJsModule = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((_needsJsModule || firstRender) && ResolvedContent is not null)
        {
            _module ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/DrawnUi.Blazor.Server/serverCanvas.js");

            var elementSize = await _module.InvokeAsync<ElementSize>("getElementSize", _imageElement);
            _displayWidth = elementSize.Width;
            _displayHeight = elementSize.Height;
            await _module.InvokeVoidAsync(
                "configureTapEffects",
                _imageElement,
                _hostElement,
                _renderedWidth,
                _renderedHeight,
                CreateTapEffectBounds());

            _needsJsModule = false;
        }
    }

    private RenderSize ResolveRenderSize()
    {
        var renderWidth = Math.Max(1, WidthRequest ?? Width);
        var renderHeight = HeightRequest ?? Height;
        var resolvedHeight = renderHeight is > 0
            ? renderHeight.Value
            : MeasureAutoHeight(renderWidth);

        return new RenderSize(renderWidth, resolvedHeight);
    }

    private int MeasureAutoHeight(int width)
    {
        if (ResolvedContent is null)
        {
            return DefaultAutoMeasureExtent;
        }

        var heightConstraint = Math.Max(_renderedHeight, DefaultAutoMeasureExtent);

        for (var attempt = 0; attempt < MaxAutoMeasurePasses; attempt++)
        {
            var measured = ResolvedContent.Measure(width, heightConstraint, 1f);
            var measuredHeight = Math.Max(1, (int)Math.Ceiling(measured.Pixels.Height));

            if (!measured.HeightCut)
            {
                return measuredHeight;
            }

            heightConstraint = Math.Max(heightConstraint * 2, measuredHeight + DefaultAutoMeasureExtent);
        }

        return heightConstraint;
    }

    private void EnsureHost(int width, int height)
    {
        if (_host is not null
            && _renderedWidth == width
            && _renderedHeight == height
            && Equals(_renderedBackgroundColor, BackgroundColor))
        {
            return;
        }

        _host?.Dispose();
        _host = new DrawnUi.Blazor.Server.HeadlessCanvasHost(width, height, BackgroundColor);
        _renderedWidth = width;
        _renderedHeight = height;
        _renderedBackgroundColor = BackgroundColor;
    }

    private async Task RenderFrameAsync(CancellationToken cancellationToken = default)
    {
        if (_host is null)
        {
            _imageSource = null;
            return;
        }

        _host.Render();
        using var image = _host.Snapshot();
        var frame = await FrameEncoder.EncodeAsync(image, cancellationToken);
        _imageSource = frame.ToDataUrl();
    }

    private async Task HandlePointerDownAsync(MouseEventArgs args)
    {
        if (_host is null || ResolvedContent is null)
        {
            return;
        }

        var point = GetRelativePoint(args);
        _pointerIsDown = true;
        _pointerDownLocation = new PointF(point.X, point.Y);
        _activeGestureListener = DispatchPointerDown(point);

        await RenderFrameAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandlePointerUpAsync(MouseEventArgs args)
    {
        if (_host is null || ResolvedContent is null || !_pointerIsDown)
        {
            return;
        }

        var point = GetRelativePoint(args);
        _pointerIsDown = false;
        DispatchGestureToActiveListener(point, TouchActionResult.Tapped);
        DispatchGestureToActiveListener(point, TouchActionResult.Up);
        _activeGestureListener = null;

        await RenderFrameAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandlePointerLeaveAsync(MouseEventArgs args)
    {
        if (_host is null || ResolvedContent is null || !_pointerIsDown)
        {
            return;
        }

        var point = GetRelativePoint(args);
        _pointerIsDown = false;
        DispatchGestureToActiveListener(point, TouchActionResult.Up);
        _activeGestureListener = null;

        await RenderFrameAsync();
        await InvokeAsync(StateHasChanged);
    }

    private RelativePoint GetRelativePoint(MouseEventArgs args)
    {
        var displayWidth = _displayWidth > 0 ? _displayWidth : _renderedWidth;
        var displayHeight = _displayHeight > 0 ? _displayHeight : _renderedHeight;
        var scaleX = _renderedWidth / Math.Max(1f, displayWidth);
        var scaleY = _renderedHeight / Math.Max(1f, displayHeight);

        return new RelativePoint
        {
            X = Math.Clamp((float)args.OffsetX * scaleX, 0f, _renderedWidth),
            Y = Math.Clamp((float)args.OffsetY * scaleY, 0f, _renderedHeight)
        };
    }

    private ISkiaGestureListener? DispatchPointerDown(RelativePoint point)
    {
        if (_host is null)
        {
            return null;
        }

        var gestureArgs = CreateGestureParameters(point, TouchActionResult.Down);
        var processingInfo = CreateProcessingInfo(point);

        foreach (var listener in _host.Canvas.GestureListeners.GetListeners())
        {
            if (listener == null || !listener.CanDraw || listener.InputTransparent)
            {
                continue;
            }

            if (!listener.HitIsInside(point.X, point.Y))
            {
                continue;
            }

            var consumed = listener.OnSkiaGestureEvent(gestureArgs, processingInfo);
            if (consumed != null)
            {
                _host.Canvas.FocusedChild = consumed;
                return consumed;
            }
        }

        return null;
    }

    private void DispatchGestureToActiveListener(RelativePoint point, TouchActionResult actionResult)
    {
        if (_activeGestureListener is null)
        {
            return;
        }

        var gestureArgs = CreateGestureParameters(point, actionResult);
        var processingInfo = CreateProcessingInfo(point);

        _activeGestureListener.OnSkiaGestureEvent(gestureArgs, processingInfo);
    }

    private GestureEventProcessingInfo CreateProcessingInfo(RelativePoint point)
    {
        var processingInfo = GestureEventProcessingInfo.Empty;
        processingInfo.MappedLocation = new SkiaSharp.SKPoint(point.X, point.Y);
        return processingInfo;
    }

    private SkiaGesturesParameters CreateGestureParameters(RelativePoint point, TouchActionResult actionResult)
    {
        var actionType = actionResult == TouchActionResult.Down
            ? TouchActionType.Pressed
            : TouchActionType.Released;

        var touchArgs = new TouchActionEventArgs(
            PointerId,
            actionType,
            new PointF(point.X, point.Y),
            ResolvedContent?.BindingContext)
        {
            IsInsideView = true,
            NumberOfTouches = 1,
            StartingLocation = _pointerDownLocation
        };

        return SkiaGesturesParameters.Create(actionResult, touchArgs);
    }

    private List<TapEffectBounds> CreateTapEffectBounds()
    {
        if (ResolvedContent is null)
        {
            return new List<TapEffectBounds>();
        }

        var result = new List<TapEffectBounds>();

        foreach (var control in EnumerateControls(ResolvedContent))
        {
            if (control is not SkiaButton button || !button.CanDraw || button.InputTransparent)
            {
                continue;
            }

            var bounds = button.MainFrame?.DrawingRect ?? button.DrawingRect;
            var radius = button.MainFrame is not null
                ? (float)button.MainFrame.CornerRadius.TopLeft
                : 0f;

            result.Add(new TapEffectBounds
            {
                Left = bounds.Left,
                Top = bounds.Top,
                Width = bounds.Width,
                Height = bounds.Height,
                Radius = radius
            });
        }

        result.Sort((left, right) =>
        {
            var leftArea = left.Width * left.Height;
            var rightArea = right.Width * right.Height;
            return leftArea.CompareTo(rightArea);
        });

        return result;
    }

    private static IEnumerable<SkiaControl> EnumerateControls(SkiaControl root)
    {
        yield return root;

        foreach (var view in root.Views)
        {
            foreach (var child in EnumerateControls(view))
            {
                yield return child;
            }
        }
    }

    private async ValueTask DisposeHostAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The browser circuit can disconnect before the server-side image host is disposed.
            }

            _module = null;
        }

        _host?.Dispose();
        _host = null;
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeHostAsync();
    }

    private sealed class RelativePoint
    {
        public float X { get; set; }

        public float Y { get; set; }
    }

    private sealed class ElementSize
    {
        public float Width { get; set; }

        public float Height { get; set; }
    }

    private sealed class TapEffectBounds
    {
        public float Left { get; set; }

        public float Top { get; set; }

        public float Width { get; set; }

        public float Height { get; set; }

        public float Radius { get; set; }
    }

    private readonly record struct RenderSize(int Width, int Height);
}