{
  "name": "drawnui-maui-docs",
  "version": "1.0.0",
  "description": "Documentation for DrawnUi",
  "main": "index.js",
  "scripts": {
    "install-docfx": "npm install --no-save @docfx/lib",
    "build": "npx docfx build",
    "build:content": "npx docfx build docfx.content.json",
    "serve": "npx docfx serve _site",
    "watch": "powershell -ExecutionPolicy Bypass -File ../dev/docs-watch.ps1",
    "watch:content": "powershell -ExecutionPolicy Bypass -File ../dev/docs-watch-content.ps1",
    "watch:wasm": "powershell -ExecutionPolicy Bypass -File ../dev/docs-watch-with-wasm.ps1"
  },
  "keywords": ["documentation", "docfx", "maui"],
  "author": "",
  "license": "ISC"
}
