{
  "build": {
    "sitemap": {
      "baseUrl": "https://drawnui.net",
      "priority": 0.5,
      "changefreq": "weekly"
    },
    "content": [
      {
        "files": [
          "articles/**.md",
          "toc.yml",
          "*.md"
        ]
      },
      {
        "files": [
          "api/index.md",
          "api/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "styles/**"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "_site-content",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern",
      "my-template"
    ],
    "styles": {
      "website": [
        "styles/main.css"
      ]
    },
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": true,
    "disableGitFeatures": false,
    "force": true,
    "globalMetadata": {
      "_appTitle": "DrawnUI for .NET",
      "_appDescription": "DrawnUI for .NET - hardware-accelerated rendering engine powered by SkiaSharp for MAUI, Blazor, and platform-agnostic hosts through DrawnUi.Net.",
      "_appKeywords": ".NET, .NET MAUI, Blazor, DrawnUi.Net, SkiaSharp, cross-platform UI, hardware acceleration, custom controls, animations, gestures, rendering engine",
      "_appAuthor": "Nick Kovalsky aka AppoMobi (@taublast)",
      "_appFooter": "Made by <a href=\"https://taublast.github.io/about/\">Nick Kovalsky aka AppoMobi (@taublast)</a><script>(function(){try{const fix=function(){const brand=document.querySelector('a.navbar-brand');if(brand){brand.setAttribute('href','/');}document.querySelectorAll('a[href]').forEach(function(a){var href=a.getAttribute('href');if(!href||href.startsWith('http'))return;if(href==='index.html'||href==='/index.html'||href==='../index.html'){a.setAttribute('href','/');return;}if(href.endsWith('/articles/index.html')||href==='articles/index.html'||href==='../articles/index.html'){a.setAttribute('href','/articles/');return;}var m=href.match(/^(?:\\.?\\.?\\/)?articles\\/.*\\/index\\.html(.*)$/);if(m){var p=href.replace(/\\/index\\.html(.*)$/,'/');if(!p.startsWith('/')){p='/' + p.replace(/^\\/?/,'');}a.setAttribute('href',p);}});};if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',fix);}else{fix();}}catch(e){})();</script>",
      "_enableSearch": true,
      "_disableContribution": false,
      "_disableBreadcrumb": false,
      "_enableNewTab": true,
      "description": "DrawnUI for .NET - hardware-accelerated rendering engine powered by SkiaSharp for MAUI, Blazor, and platform-agnostic hosts through DrawnUi.Net.",
      "keywords": ".NET, .NET MAUI, Blazor, DrawnUi.Net, SkiaSharp, cross-platform UI, hardware acceleration, custom controls, animations, gestures, rendering engine",
      "author": "Nick Kovalsky aka AppoMobi (@taublast)",
      "og:title": "DrawnUI for .NET",
      "og:description": "Choose the right DrawnUI runtime for .NET MAUI, Blazor, or platform-agnostic rendering workflows.",
      "og:type": "website",
      "og:url": "https://drawnui.net",
      "og:image": "https://drawnui.net/images/logo.png",
      "twitter:card": "summary_large_image",
      "twitter:title": "DrawnUI for .NET",
      "twitter:description": "Hardware-accelerated rendering engine for .NET, including MAUI and Blazor.",
      "_gitContribute": {
        "repo": "https://github.com/taublast/drawnui",
        "branch": "main"
      },
      "_appLogoPath": "images/draw.svg",
      "_appFaviconPath": "images/draw.svg",
      "_disableAffix": false,
      "_disableNavbar": false,
      "_disableSideFilter": false,
      "_disableToc": false,
      "_noCache": true,
      "_buildTime": "{{BUILD_TIMESTAMP}}"
    }
  }
}